#!/usr/bin/env perl

use strict;
use warnings;
use Getopt::Long;
use File::Basename;
use POSIX qw(strftime);

my ($input_bed, $input_bam, $input_depth, $thresholds_str, $output_file, $help);
my $threads;
my $num_args = scalar @ARGV;
my $log_fh = initialize_log_fh();

my $usage = <<"USAGE";
Usage: $0 --bed BED_FILE [--bam BAM_FILE | --depth DEPTH_FILE] [--thresholds THRESHOLDS] [--threads INT] [--output FILE]
       $0 --help

Parameters:
  --help, -h
      Print this help text and exit.
  --bed BED_FILE
      Required BED file with 0-based intervals.
      Expected columns: chrom, start, end, region_name.
  --bam BAM_FILE
      BAM/CRAM input. The script runs samtools depth -a -b BED_FILE.
  --depth DEPTH_FILE
      Precomputed depth file input. The script streams this file directly.
      Expected format: chrom, 1-based position, depth.
      The file should be position-sorted and should ideally be generated with:
      samtools depth -a -b BED_FILE BAM_FILE
  --thresholds THRESHOLDS
      Comma-separated depth thresholds. Default: 10,50
  --threads INT
      Threads passed to samtools depth for --bam input only.
      Default: detected CPU count minus 2, minimum 1.
  --output FILE
      Write tab-delimited output to a file instead of stdout.
      Status and progress messages are written to the terminal when available.
USAGE

GetOptions(
    'bed=s'        => \$input_bed,
    'bam=s'        => \$input_bam,
    'depth=s'      => \$input_depth,
    'thresholds=s' => \$thresholds_str,
    'threads=i'    => \$threads,
    'output=s'     => \$output_file,
    'help|h'       => \$help,
) or die $usage;

$SIG{__WARN__} = sub {
    my ($message) = @_;
    chomp $message;
    log_warn($message);
};

if ($help || $num_args == 0) {
    print $usage;
    exit;
}

fatal("Bed file is required") unless $input_bed;
fatal("Bed file does not exist: $input_bed") unless -e $input_bed;
fatal("Either bam or depth file is required") unless $input_bam || $input_depth;
fatal("Provide either bam or depth, not both") if $input_bam && $input_depth;
fatal("Bam file does not exist: $input_bam") if $input_bam && !-e $input_bam;
if ($input_bam) {
    my $bai = $input_bam . ".bai";
    my $csi = $input_bam . ".csi";
    my $crai = $input_bam . ".crai";
    fatal("BAM index not found (run: samtools index $input_bam)")
        unless -e $bai || -e $csi || -e $crai;
}
fatal("Depth file does not exist: $input_depth") if $input_depth && !-e $input_depth;

if (!defined $threads) {
    my $cpu_count = get_cpu_count();
    $threads = $cpu_count - 2;
    $threads = 1 if $threads < 1;
}

my @thresholds = sort { $a <=> $b } ($thresholds_str ? split /,/, $thresholds_str : (10, 50));
for my $t (@thresholds) {
    fatal("Invalid threshold '$t': must be a positive number") unless $t =~ /^\d+(?:\.\d+)?$/ && $t > 0;
}
my $thresholds_display = join(',', @thresholds);

my $sample = $input_bam
    ? fileparse($input_bam, qr/\.[^.]*/)
    : fileparse($input_depth, qr/\.[^.]*/);

my @header = (
    "ID", "chrom", "start", "end", "total_bases", "region", "avg_depth",
    (map { $_ . "x" } @thresholds),
    (map { $_ . "x(%)" } @thresholds),
);

log_run_configuration(
    bed => $input_bed,
    bam => $input_bam,
    depth => $input_depth,
    output => $output_file,
    thresholds => $thresholds_display,
    threads => $threads,
);

my @regions;
my %regions_by_chr;
log_info("Loading BED file $input_bed");
open(my $bed_fh, '<', $input_bed) or fatal("Can't read the BED file: $input_bed");
while (my $rec = <$bed_fh>) {
    chomp $rec;
    next if $rec =~ /^\s*$/;
    my @fields = split(/\t/, $rec);
    fatal("BED file format error: expected at least 3 columns (chr, start, end), got " . scalar(@fields)) unless @fields >= 3;
    my ($chr, $start, $end, $info) = @fields;
    $chr =~ s/\s+//g;
    $start =~ s/\s+//g;
    $end =~ s/\s+//g;
    fatal("BED file format error: start must be a non-negative integer") unless $start =~ /^\d+$/;
    fatal("BED file format error: end must be a non-negative integer") unless $end =~ /^\d+$/;
    fatal("BED file format error: end must be >= start") unless $end >= $start;
    my $total_bases = $end - $start;
    $start += 1;
    my $region = {
        chr => $chr,
        start => $start,
        end => $end,
        total_bases => $total_bases,
        info => $info // "unknown",
        sum => 0,
        counters => [(0) x scalar @thresholds],
    };
    push @regions, $region;
    push @{ $regions_by_chr{$chr} }, $#regions;
}
close $bed_fh;

for my $chr (keys %regions_by_chr) {
    @{ $regions_by_chr{$chr} } = sort {
        $regions[$a]{start} <=> $regions[$b]{start}
            ||
        $regions[$a]{end} <=> $regions[$b]{end}
    } @{ $regions_by_chr{$chr} };
}

my $depth_fh = open_depth_fh($input_bam, $input_bed, $input_depth, $threads);
process_depth_stream($depth_fh, \@regions, \%regions_by_chr, \@thresholds);
close $depth_fh;

my $out_fh;
if ($output_file) {
    open($out_fh, '>', $output_file) or fatal("Can't open output file $output_file: $!");
} else {
    $out_fh = *STDOUT;
}

print $out_fh join("\t", @header) . "\n";
for my $region (@regions) {
    print $out_fh join("\t", format_region_output($sample, $region)) . "\n";
}

close $out_fh if $output_file;
my $destination = $output_file // 'stdout';
log_info("Done. Output file $destination");

sub open_depth_fh {
    my ($bam, $bed, $depth, $thread_count) = @_;

    if ($bam) {
        log_info("Starting samtools depth for BAM/CRAM input using alignment file $bam. This can take a while for large files.");
        open(my $fh, '-|', 'samtools', 'depth', '-a', '-@', $thread_count, '-b', $bed, $bam)
            or fatal("Failed to run samtools depth");
        return $fh;
    }

    log_info("Loading depth file $depth");
    open(my $fh, '<', $depth) or fatal("Can't open depth file $depth: $!");
    return $fh;
}

sub process_depth_stream {
    my ($depth_fh, $regions_ref, $regions_by_chr_ref, $thresholds_ref) = @_;
    my %next_region_idx;
    my %active_regions;
    my $last_logged_region_idx;

    while (my $line = <$depth_fh>) {
        chomp $line;
        next if $line =~ /^\s*$/;
        my @fields = split(/\t/, $line);
        fatal("Depth file format error: expected 3 columns (chr, pos, depth), got " . scalar(@fields)) unless @fields == 3;
        my ($chr, $pos, $depth) = @fields;
        $chr =~ s/\s+//g;
        $pos =~ s/\s+//g;
        $depth =~ s/\s+//g;
        fatal("Depth file format error: position must be a positive integer") unless $pos =~ /^\d+$/ && $pos > 0;
        fatal("Depth file format error: depth must be a non-negative integer") unless $depth =~ /^\d+$/;
        next unless exists $regions_by_chr_ref->{$chr};

        my $region_indexes = $regions_by_chr_ref->{$chr};
        my $next_idx = $next_region_idx{$chr} // 0;

        while ($next_idx < @$region_indexes && $regions_ref->[ $region_indexes->[$next_idx] ]{start} <= $pos) {
            push @{ $active_regions{$chr} }, $region_indexes->[$next_idx];
            $next_idx++;
        }
        $next_region_idx{$chr} = $next_idx;

        next unless exists $active_regions{$chr};

        my @still_active;
        my $first_overlapping_idx;
        for my $region_idx (@{ $active_regions{$chr} }) {
            my $region = $regions_ref->[$region_idx];
            next if $region->{end} < $pos;
            push @still_active, $region_idx;
            next if $region->{start} > $pos;

            $first_overlapping_idx //= $region_idx;

            $region->{sum} += $depth;
            for my $i (0 .. $#$thresholds_ref) {
                if ($depth >= $thresholds_ref->[$i]) {
                    $region->{counters}[$i]++;
                } else {
                    last;
                }
            }
        }
        $active_regions{$chr} = \@still_active;

        if (defined $first_overlapping_idx && (!defined $last_logged_region_idx || $last_logged_region_idx != $first_overlapping_idx)) {
            $last_logged_region_idx = $first_overlapping_idx;
            log_info("Calculating depth for BED interval " . format_region_label($regions_ref->[$first_overlapping_idx]));
        }
    }
}

sub format_region_output {
    my ($sample_name, $region) = @_;
    my $avg_depth = $region->{total_bases} > 0 ? sprintf("%.2f", $region->{sum} / $region->{total_bases}) : "0";
    my @percentages = $region->{total_bases} > 0
        ? map { sprintf("%.2f", ($_ / $region->{total_bases}) * 100) } @{ $region->{counters} }
        : map { "0" } @{ $region->{counters} };
    return (
        $sample_name,
        $region->{chr},
        $region->{start},
        $region->{end},
        $region->{total_bases},
        $region->{info},
        $avg_depth,
        @{ $region->{counters} },
        @percentages,
    );
}

sub get_cpu_count {
    if (open my $fh, '<', '/proc/cpuinfo') {
        my $count = 0;
        while (<$fh>) {
            $count++ if /^processor\s*:/;
        }
        close $fh;
        return $count if $count > 0;
    }
    return 1;
}

sub log_info {
    my ($message) = @_;
    log_message('INFO', $message);
}

sub log_warn {
    my ($message) = @_;
    log_message('WARN', $message);
}

sub log_error {
    my ($message) = @_;
    log_message('ERROR', $message);
}

sub fatal {
    my ($message) = @_;
    log_error($message);
    exit 1;
}

sub log_message {
    my ($level, $message) = @_;
    my $timestamp = strftime('%Y/%m/%d %H:%M:%S', localtime);
    printf {$log_fh} "%-5s %s > %s\n", $level, $timestamp, $message;
}

sub format_region_label {
    my ($region) = @_;
    return "$region->{chr}:$region->{start}-$region->{end} ($region->{info})";
}

sub log_run_configuration {
    my (%args) = @_;
    my $input_type = $args{bam} ? 'bam' : 'depth';
    my $input_value = $args{bam} // $args{depth};
    my $output_value = $args{output} // 'stdout';
    my $message = "Parameters: --bed $args{bed} --$input_type $input_value --thresholds $args{thresholds}";
    $message .= " --threads $args{threads}" if $args{bam};
    $message .= " --output $output_value";
    log_info($message);
}

sub initialize_log_fh {
    my $fh = *STDOUT;

    if (-t STDOUT && open(my $tty_fh, '>', '/dev/tty')) {
        $fh = $tty_fh;
    }

    my $previous = select $fh;
    $| = 1;
    select $previous;

    return $fh;
}
